# Core OpenClaw gateway
OPENAI_API_KEY=
OPENAI_TOOLS_API_KEY=
OPENAI_BASE_URL=http://ai-services:8010/v1
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_VERSION=2026.2.9
OPENCLAW_CLI_PATH=$HOME/.local/openclaw/node_modules/openclaw/dist/index.js
PRIMARY_TEXT_MODEL=minimax-m2.5
PRIMARY_VISION_MODEL=internvl
EMBEDDINGS_MODEL=bge-small-en-v1.5
PLANNER_TEMP=0.25
CODER_TEMP=0.18
TESTER_TEMP=0.10

# Telegram task commands + alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALLOW_FROM=

# Postgres for autonomous_tasks
OPENCLAW_POSTGRES_HOST=localhost
OPENCLAW_POSTGRES_PORT=5433
OPENCLAW_POSTGRES_DB=openclaw
OPENCLAW_POSTGRES_USER=openclaw
OPENCLAW_POSTGRES_PASSWORD=
OPENCLAW_DB_UI_PORT=8080

# Task manager controls
MAX_ATTEMPTS=2
TESTER_MAX_ATTEMPTS=3
VERBOSE_TASK_LOGS=1
TASK_HEARTBEAT_SEC=120
TEST_CLEANUP_AFTER=1
TESTER_TIMEOUT=2400
TESTER_STEP_TIMEOUT=600

# Chat router + Telegram ack
CHAT_ROUTER_PORT=18801
CHAT_ROUTER_URL=http://127.0.0.1:18801/route
CHAT_ROUTER_ASK_TIMEOUT_SEC=180
TELEGRAM_ACK_REACTION=✅

# Model health checker tuning
MODEL_HEALTH_RETRIES=2
MODEL_HEALTH_CONNECT_TIMEOUT_SEC=5
MODEL_HEALTH_MODELS_TIMEOUT_SEC=20
MODEL_HEALTH_CHAT_TIMEOUT_SEC=90
MODEL_HEALTH_EMBED_TIMEOUT_SEC=60

# Agent skills repo
AGENT_SKILLS_REPO=https://github.com/gohypergiant/agent-skills.git

# Microsoft 365 integration (optional)
# Create an Azure App Registration with Mail.Read, Mail.Send, Calendars.ReadWrite
# Save credentials to ~/.openclaw/microsoft-credentials.json:
#   {"client_id": "...", "client_secret": "...", "tenant_id": "..."}
MS365_USER_EMAIL=

# Twilio phone integration (optional)
# Save credentials to ~/.openclaw/twilio-credentials.json:
#   {"account_sid": "...", "auth_token": "...", "phone_number": "+1..."}
TWILIO_PHONE_NUMBER=
TWILIO_FORWARD_TO=

# Coding bot (Tailscale) integration (optional)
# Set to the Tailscale HTTPS URL of the coding bot for build prompt handoff
CODING_BOT_URL=
